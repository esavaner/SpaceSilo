{
  "name": "@repo/shared",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslint": "./eslint.shared.mjs",
    "./tailwind": "./tailwind.config.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,js,tsx,jsx}\"",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.json",
    "check": "pnpm lint && pnpm typecheck",
    "lint:fix": "eslint \"src/**/*.{ts,js,tsx,jsx}\" --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset:dev": "prisma migrate reset --force",
    "db:seed:dev": "node --loader @swc-node/register/esm --experimental-specifier-resolution=node ./src/prisma/seed.ts",
    "reset": "pnpm db:reset:dev && pnpm build && pnpm db:seed:dev",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.3.0",
    "@prisma/client": "7.3.0",
    "dotenv": "17.2.3",
    "pg": "8.17.2"
  },
  "peerDependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3"
  },
  "devDependencies": {
    "@swc-node/register": "^1.9.2",
    "prisma": "7.3.0",
    "tailwindcss": "^4.1.18",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3"
  }
}
