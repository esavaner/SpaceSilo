generator client {
  provider = "prisma-client"
  output   = "./generated"
}

// generator prismaClassGenerator {
//   provider = "prisma-class-generator"
//   separateRelationFields = true
//   dryRun = false
// }

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  admin
  user
}

enum BackupDirection {
  outgoing
  incoming
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  settings  Json?

  photos    Photo[]
  albums    Album[]
  notes     Note[]
  backups   Backup[]
  ownerOf   Group[]
  memberOf  GroupMember[]
}


model Backup {
  id                       String          @id @default(cuid())
  pairId                   String          @unique
  pairSecret               String
  direction                BackupDirection
  active                   Boolean         @default(true)
  schedule                 String
  copyPhotos               Boolean         @default(false)
  copyFiles                Boolean         @default(false)
  copyNotes                Boolean         @default(false)
  sourceServerLabel        String
  sourceServerBaseUrl      String
  sourceServerKey          String
  destinationServerLabel   String
  destinationServerBaseUrl String
  destinationServerKey     String
  destinationPath          String?
  remoteConfigId           String?
  runCount                 Int             @default(0)
  running                  Boolean         @default(false)
  lastRunAt                DateTime?
  lastStartedAt            DateTime?
  lastFinishedAt           DateTime?
  lastSuccessAt            DateTime?
  lastError                String?
  nextRunAt                DateTime?
  lastStats                Json?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  createdById              String
  createdBy                User            @relation(fields: [createdById], references: [id])

  @@index([direction, active, nextRunAt])
  @@index([createdById, direction])
}


model Photo {
  id        String   @id @default(cuid())
  url       String
  path      String
  thumbnailPath String
  hash      String
  metadata  Json?
  capturedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  albums    Album[]
  group     Group[]

  @@index([ownerId, capturedAt, createdAt])
}

model Album {
  id        String   @id @default(cuid())
  name      String
  capturedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  parentId  String?
  parent    Album?   @relation("Subalbums", fields: [parentId], references: [id])
  subalbums Album[]  @relation("Subalbums")
  photos    Photo[]
  group     Group[]

  @@index([ownerId, capturedAt, createdAt])
  @@index([parentId, capturedAt, createdAt])
}


model Group {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  personal  Boolean?  @default(false)
  color     String?
  members   GroupMember[]
  albums    Album[]
  photos    Photo[]
  notes     Note[]
}

model Note {
  id        String   @id @default(cuid())
  title     String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])

  @@index([groupId, updatedAt, createdAt])
  @@index([ownerId, updatedAt, createdAt])
}

enum GroupAccessLevel {
  admin
  edit
  read
}

model GroupMember {
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  access    GroupAccessLevel @default(read)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@id([groupId, userId])
}